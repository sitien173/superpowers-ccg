{
  "mcpServers": {
    "openmcp": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/sitien173/superpowers-ccg#subdirectory=openmcp/openmcp",
        "openmcp"
      ],
      "env": {
        "OPENMCP_AGY_MODEL_DEFAULT": "gemini-3.1-pro-high",
        "OPENMCP_CODEX_MODEL_DEFAULT": "gpt-5.4",
        "OPENMCP_GEMINI_MODEL_DEFAULT": "gemini-3.1-pro-preview",
        "OPENMCP_CODEX_PROFILE_DEFAULT": "mcp_execution",
        "OPENMCP_AGY_REASONING_MODEL": "gemini-3.1-pro-high",
        "OPENMCP_CODEX_REASONING_MODEL": "gpt-5.5",
        "OPENMCP_GEMINI_REASONING_MODEL": "gemini-3.1-pro-preview",
        "OPENMCP_GEMINI_ROUTE_TO_AGY": "false",
        "OPENMCP_LOG_FILE": "~/.openmcp/openmcp.log",
        "OPENMCP_LOG_LEVEL": "INFO"
      }
    }
  }
}
