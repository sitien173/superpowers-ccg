{
  "mcpServers": {
    "openmcp": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/sitien173/openmcp.git#subdirectory=openmcp",
        "openmcp"
      ]
    },
    "context-retrieval": {
      "command": "auggie",
      "args": [
        "--mcp",
        "--mcp-auto-workspace"
      ]
    }
  }
}
