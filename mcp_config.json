{
  "mcpServers": {
    "openmcp": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/sitien173/openmcp.git#subdirectory=openmcp",
        "openmcp"
      ]
    },
    "context-retrieval": {
      "command": "auggie",
      "args": [
        "--mcp",
        "--mcp-auto-workspace"
      ]
    },
    "serena": {
      "command": "npx",
      "args": [
        "-y",
        "@respawn-app/tool-filter-mcp",
        "--upstream-stdio",
        "--deny",
        "replace_.*,insert_.*,rename_.*,safe_delete_symbol,.*memor.*,onboarding",
        "--",
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "."
      ]
    }
  }
}
